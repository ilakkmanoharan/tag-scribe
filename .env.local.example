# Firebase (tag-scribe-fa346) — copy to .env.local and fill
# Client (NEXT_PUBLIC_*) — from Firebase Console → Project settings → Your apps
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=tag-scribe-fa346.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=tag-scribe-fa346
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=tag-scribe-fa346.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=809979861160
NEXT_PUBLIC_FIREBASE_APP_ID=1:809979861160:web:e17ef13d907c0b0304ca9d
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-0JYWLXQZHB

# Server (Admin SDK) — use one of:
# 1) Path to service account JSON (download from Firebase Console → Service accounts → Generate new private key)
GOOGLE_APPLICATION_CREDENTIALS=./private/firebase/serviceAccountKey.json
# 2) Or paste the full JSON as a single line (no newlines):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Optional: for seed/verify scripts
# FIREBASE_SEED_EMAIL=seed@tag-scribe.local
# FIREBASE_SEED_PASSWORD=your-seed-password

# iOS auth (Sign in with Apple → our JWT). Required for POST /api/auth/apple.
JWT_SECRET=your-32-byte-or-longer-secret-for-signing-jwts
# Optional: iOS app bundle ID for Apple token audience (default: app.tagscribe.ios)
# APPLE_BUNDLE_ID=app.tagscribe.ios
